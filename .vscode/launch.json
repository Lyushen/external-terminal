{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "runtimeExecutable": "${execPath}",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}",
                "--disable-extensions",
                "${workspaceFolder}/node_modules"
            ],
            "outFiles": [
                "${workspaceFolder}/out/**/*.js"
            ],
            "internalConsoleOptions": "neverOpen",
            "preLaunchTask": "npm: build"
        }
    ]
}
